# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/clinica_aviva
DB_USER=postgres
DB_PASSWORD=change-me

# JWT: use a long random value outside development
JWT_SECRET=change-me-with-at-least-32-characters
JWT_EXPIRATION=86400000

# Brevo transactional email
BREVO_API_KEY=change-me
MAIL_FROM=clnicaviva@gmail.com
MAIL_FROM_NAME=Clinica Aviva

# Notification worker
NOTIFICATION_PROCESSING_DELAY_MS=60000
NOTIFICATION_SCHEDULER_ENABLED=true
